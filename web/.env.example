# Next carga al arrancar: `../.env` → `web/.env` → `web/.env.local` (este último pisa lo anterior).
# Creá tu local sin commitear:
#   cp .env.example .env.local
# Completá solo las claves que quieras distintas o que no estén en `../.env`.
# No dejes líneas `CLAVE=` vacías si esa clave ya está bien en `../.env` (la vacía la pisaría).

# --- Google Sheets (lectura con service account) ---
GOOGLE_SHEETS_SPREADSHEET_ID=

# Opción A: JSON del Service Account en una línea (Vercel / sin archivo en disco)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Opción B: ruta al JSON en el disco (local / VPS)
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/al/sa.json

# Opcional: SA desde SQLite de n8n en Docker (solo si aplica)
# N8N_DOCKER_CONTAINER=n8n
# N8N_GOOGLE_CREDENTIAL_NAME=Google Sheets account 2

# Caché en memoria de lectura Sheets (ms). En Vercel suele ser 0.
# SHEETS_CACHE_TTL_MS=10000

# --- Origen de datos del dashboard (capa web/lib/data/) ---
# sheets (default) = Google Sheets. neon = Postgres (Neon); hace falta DATABASE_URL y aún falta implementar SQL.
# SALDU_DASHBOARD_DATA_SOURCE=sheets
# DATABASE_URL=postgresql://...neon.tech/...?sslmode=require

# --- Webhook n8n → notify + versión en Redis ---
# NOTIFY_SECRET=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# (alternativa Vercel KV)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Multi-usuario (login Google + planilla por usuario en Redis) ---
# Solo si están las cuatro primeras + Redis + plantilla, la app pide login y copia la plantilla por usuario.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Local: debe coincidir con la URL y puerto donde corrés Next (barra de direcciones).
# Si Next usa otro puerto (p. ej. 3009 porque 3000 está ocupado), poné http://localhost:3009
# y agregá en Google Cloud → OAuth → «URI de redireccionamiento autorizados»:
#   http://localhost:PUERTO/api/auth/callback/google
# Si no, Google vuelve al 3000 y otra app responde «ruta no encontrada».
AUTH_URL=http://localhost:3000
# Si Google no devuelve refresh_token al reloguear: 1 o true (fuerza pantalla de consentimiento cada login).
# AUTH_GOOGLE_PROMPT_CONSENT=1

# ID de la planilla plantilla (compartida con la service account); se copia con Drive API.
SALDU_TEMPLATE_SPREADSHEET_ID=

# Si Drive devuelve «File not found» al copiar pero la planilla abre en el navegador: a veces hace falta
# la clave de recurso de enlaces compartidos. Copiá el valor de resourcekey= de la URL (o de la API).
# https://developers.google.com/workspace/drive/api/guides/resource-keys
# SALDU_TEMPLATE_SPREADSHEET_RESOURCE_KEY=

# Opcional: carpeta destino (ID en la URL de la carpeta). Útil en Google Workspace + Shared Drive
# para que las copias no consuman la cuota mínima del “My Drive” de la service account.
# SALDU_DRIVE_COPY_PARENT_FOLDER_ID=

# Opcional: al copiar con OAuth del usuario, carpeta en el «Mi unidad» de ESE usuario (solo ID de carpeta tuya).
# No reutilices SALDU_DRIVE_COPY_PARENT_FOLDER_ID (suele ser Shared Drive de la service account → 404 al copiar).
# SALDU_USER_DRIVE_COPY_PARENT_FOLDER_ID=
# Misma idea que la plantilla: si esa carpeta solo existe vía enlace con resource key:
# SALDU_USER_DRIVE_COPY_PARENT_FOLDER_RESOURCE_KEY=

# Consentimiento OAuth: en Google Cloud Console (pantalla de consentimiento) agregá los scopes
# …/auth/drive y …/auth/spreadsheets (Saldu copia la plantilla con Drive.files.copy en el Drive del usuario).
# Si cambiás scopes: revocá la app en myaccount.google.com/permissions o AUTH_GOOGLE_PROMPT_CONSENT=1 y relogueá.
# Tras ampliar scopes (ej. drive), subí este número. Con valor definido, el login usa prompt=consent
# para que Google vuelva a mandar refresh_token (si no, verás NO_REFRESH_TOKEN). Luego podés quitar
# esta variable si no querés consentimiento en cada login. Para forzar solo a mano: AUTH_GOOGLE_PROMPT_CONSENT=1
# AUTH_GOOGLE_SCOPE_VERSION=2

# --- Resumen con IA (pestaña Resumen → Generar análisis) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
