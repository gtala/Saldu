# Copiar a .env (no commitear) o exportar en el shell / PM2.
GOOGLE_SHEETS_SPREADSHEET_ID=

# Opción A: JSON completo del Service Account como string (recomendado para Vercel / PaaS)
# Obtené el JSON de Google Cloud → IAM → Service Accounts → Claves → Agregar clave → JSON
# Pegá el contenido completo del archivo (una sola línea, sin saltos).
GOOGLE_SERVICE_ACCOUNT_JSON=

# Opción B: ruta al archivo JSON (servidores con filesystem, e.g. VPS con PM2)
GOOGLE_APPLICATION_CREDENTIALS=

# Opcional: leer SA desde la DB de n8n en Docker (solo en servidor con n8n).
# N8N_DOCKER_CONTAINER=n8n
# N8N_GOOGLE_CREDENTIAL_NAME=Google Sheets account 2

# Caché en memoria de lectura Sheets (ms). En Vercel se fuerza 0 automáticamente (VERCEL=1).
# En VPS podés subirlo (ej. 10000) para menos llamadas a la API de Google.
# SHEETS_CACHE_TTL_MS=10000

# --- Webhook n8n → front sin polling agresivo ---
# 1) En Vercel: Marketplace → Redis (Upstash) → vincular al proyecto (crea estas envs solas).
# 2) n8n: al final del flujo que escribe Sheets, nodo HTTP Request:
#    POST https://saldu.ar/api/notify
#    Header: Authorization: Bearer <mismo valor que NOTIFY_SECRET>
# NOTIFY_SECRET=un_secreto_largo
# UPSTASH_REDIS_REST_URL=   (auto si integrás Redis desde Vercel)
# UPSTASH_REDIS_REST_TOKEN=
